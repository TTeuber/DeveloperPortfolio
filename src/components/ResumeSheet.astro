---
// Renders one resume variant from the shared HTML files in src/data/resumes/ —
// the same files ResumeBuilder (~/Code/stuff/ResumeBuilder) previews and
// exports to PDF/Word through its resumes/ symlink. Single source of truth:
// edit the html file and the site, PDF, and Word doc all update.
// We extract the <body> content at build time and drop it into the styled
// sheet; the file's <head> (print stylesheet link, TARGET comment) is ignored.
const resumeFiles = import.meta.glob('../data/resumes/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
});

interface Props {
  variant: string;
}

const { variant } = Astro.props;
const raw = resumeFiles[`../data/resumes/${variant}.html`] as string | undefined;
if (!raw) {
  throw new Error(`No resume html for variant "${variant}" in src/data/resumes/`);
}
const match = raw.match(/<body>([\s\S]*)<\/body>/);
if (!match) {
  throw new Error(`Could not find <body> in resume html for "${variant}"`);
}
// Strip the phone number (and its trailing separator) at build time: it stays
// in the shared html for ResumeBuilder's PDF/Word exports, but never ships in
// the public site's markup.
const body = match[1].replace(/\s*<a href="tel:[^"]*">[^<]*<\/a>\s*·/g, '');
---

<article class="sheet" set:html={body} />

<!-- Global (not scoped) because Astro can't scope styles onto set:html content.
     Everything is nested under .sheet; selectors target the class conventions
     documented in ResumeBuilder's CLAUDE.md. -->
<style lang="scss" is:global>
  // The "paper sheet" — deliberately light even on the dark site, since it's a document.
  .sheet {
    max-width: 800px;
    margin: 0 auto;
    background: #fdfcf9;
    color: #1c1a16;
    border-radius: 12px;
    padding: 56px 60px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);

    a {
      color: #8a5a12;
      text-decoration: underline;
      text-decoration-color: rgba(138, 90, 18, 0.35);
      text-underline-offset: 2px;

      &:hover {
        text-decoration-color: #8a5a12;
      }
    }

    code {
      font-family: var(--font-mono);
      font-size: 0.85em;
    }

    .resume-header {
      border-bottom: 2px solid #1c1a16;
      padding-bottom: 20px;
      margin-bottom: 28px;

      h1 {
        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin: 0 0 2px;
      }

      .role {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #8a5a12;
        margin: 0 0 10px;
      }

      .contact {
        font-size: 0.875rem;
        color: #57534b;
        margin: 0;
      }
    }

    section {
      padding: 0; // cancel the global `section` padding meant for homepage sections
      margin-bottom: 28px;

      &:last-child {
        margin-bottom: 0;
      }

      h2 {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #8a5a12;
        border-bottom: 1px solid rgba(28, 26, 22, 0.15);
        padding-bottom: 6px;
        margin: 0 0 14px;
      }

      p {
        font-size: 0.9375rem;
        line-height: 1.65;
        margin: 0 0 10px;
        color: #33302a;
      }

      // Top-level list (the Skills section)
      > ul {
        margin: 0;
        padding-left: 18px;

        li {
          font-size: 0.9rem;
          line-height: 1.6;
          color: #33302a;
          margin-bottom: 5px;
        }
      }
    }

    .entry {
      margin-bottom: 16px;

      &:last-child {
        margin-bottom: 0;
      }

      h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 5px;
        color: #1c1a16;
      }

      ul {
        margin: 0;
        padding-left: 18px;
      }

      li {
        font-size: 0.9rem;
        line-height: 1.6;
        color: #33302a;
        margin-bottom: 4px;
      }

      p {
        font-size: 0.9rem;
      }
    }

    // Dated entries: role/company on the left, date range on the right
    .entry-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;

      .dates {
        flex-shrink: 0;
        font-size: 0.875rem;
        color: #57534b;
        white-space: nowrap;
      }
    }

    .links {
      font-weight: 400;
      font-size: 0.875rem;
    }

    .edu-detail {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 640px) {
    .sheet {
      padding: 32px 24px;
    }

    .sheet .entry-head {
      flex-direction: column;
      gap: 0;
    }
  }

  @media print {
    .sheet {
      max-width: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0;

      a {
        text-decoration: none;
        color: inherit;
      }
    }
  }
</style>
