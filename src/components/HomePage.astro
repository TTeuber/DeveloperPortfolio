---
// The full home page, parameterized by a variant from variants.js.
// `/` renders the general variant; /web, /ai, /audio, /cpp, /python render
// tailored versions (hero copy, project order/featured, About intro, skill
// group order, résumé links) for recruiters arriving from a tailored resume.
import { Image, getImage } from 'astro:assets';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import ProjectsGrid from './ProjectsGrid.svelte';
import { projectsForVariant, filterableTags } from '../data/projects.js';
import { skillGroups } from '../data/skills.js';
import { variants } from '../data/variants.js';
import portrait from '../assets/Portrait.jpg';

interface Props {
  variant: (typeof variants)[keyof typeof variants];
}

const { variant } = Astro.props;
const projects = projectsForVariant(variant.projects);
const aboutIntro = variant.aboutIntro ?? variants.general.aboutIntro;

// Skill groups reordered by relevance to the variant (unlisted titles sink).
const orderedSkillGroups = variant.skillGroupOrder
  ? [...skillGroups].sort((a, b) => {
      const rank = (g) => {
        const i = variant.skillGroupOrder.indexOf(g.title);
        return i === -1 ? variant.skillGroupOrder.length : i;
      };
      return rank(a) - rank(b);
    })
  : skillGroups;

// Optimized responsive variants for the project cards, one array per project.
// Only src/assets imports go through the pipeline — GIF entries keep their
// public/ path (see projects.js). `portrait` flags phone screenshots so the
// card letterboxes them instead of crop-zooming.
const cardImages = Object.fromEntries(
  await Promise.all(
    projects
      .filter((p) => p.images?.length)
      .map(async (p) => [
        p.id,
        await Promise.all(
          p.images.map(async (image) => {
            if (typeof image === 'string') return { src: image };
            const img = await getImage({
              src: image,
              format: 'webp',
              widths: [480, 960, 1440],
              sizes: '(min-width: 861px) 640px, 100vw',
            });
            return {
              src: img.src,
              srcset: img.srcSet.attribute,
              sizes: img.attributes.sizes,
              portrait: image.height > image.width,
            };
          })
        ),
      ])
  )
);
---

<Nav home={variant.path} resumePath={variant.resumePath} />

<!-- Hero -->
<section id="hero">
  <div class="hero-content">
    <p class="hero-status">
      <span class="led led-green" aria-hidden="true"></span>
      {variant.hero.status}&ensp;&middot;&ensp;GREATER SEATTLE, WA
    </p>
    <h1>Tyler<br />Teuber</h1>
    <svg class="hero-wave" viewBox="0 0 600 80" aria-hidden="true" fill="none" preserveAspectRatio="none">
      <path
        pathLength="1"
        d="M0 40h20l8-16 8 28 8-18 8 12 8-6h18l8-30 8 56 8-44 8 32 8-14h22l8-10 8 20 8-10h26l8-24 8 46 8-34 8 20 8-8h30l8-6 8 12 8-6h26l8-34 8 64 8-50 8 36 8-16h26l8-10 8 26 8-16h24l8-18 8 34 8-22 8 10 8-6h26l8-28 8 52 8-38 8 24 8-10h26l8-8 8 14 8-6h20"
        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      />
    </svg>
    <p class="hero-tagline">{variant.hero.tagline}</p>
    <div class="hero-ctas">
      <a href="#projects" class="btn btn-primary">See my work</a>
      <a href="#contact" class="btn btn-secondary">Get in touch</a>
    </div>
  </div>
</section>

<!-- Projects -->
<section id="projects">
  <div class="container reveal">
    <div class="section-head">
      <span class="section-num">01</span>
      <h2>Projects</h2>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <ProjectsGrid client:load images={cardImages} projects={projects} />
  </div>
</section>

<!-- About -->
<section id="about">
  <div class="container reveal">
    <div class="section-head">
      <span class="section-num">02</span>
      <h2>About</h2>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <div class="about-grid">
      <div class="about-portrait">
        <Image src={portrait} alt="Tyler Teuber" class="portrait" width={320} height={320} densities={[1, 2]} />
      </div>
      <div class="about-text">
        <p set:html={aboutIntro} />
        <p>
          I'm self-taught with an asterisk: since my first day of programming four years
          ago, I've met biweekly with a senior software architect who tells me what to
          learn next, and I go learn it. Along the way I've taught programming
          professionally, led a student team contributing to a
          <a href="https://playerpathwayproject.org" target="_blank" rel="noopener">production codebase</a>,
          and shipped tools that people still use every week without me.
        </p>
        <ul class="about-facts">
          <li><span class="fact-label">Education</span>B.A. Economics + Audio Technology minor, Western Washington University</li>
          <li><span class="fact-label">Mentorship</span>Biweekly with a senior software architect, 4 years running</li>
          <li><span class="fact-label">Elsewhere</span>Guitarist, recording engineer, volunteer live-audio tech</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Experience -->
<section id="experience">
  <div class="container reveal">
    <div class="section-head">
      <span class="section-num">03</span>
      <h2>Experience</h2>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <div class="timeline">

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Coding Instructor / Assistant Manager</h3>
            <span class="timeline-meta">Coding Mind &middot; Redmond, WA</span>
          </div>
          <span class="timeline-date">Aug 2024 — Present</span>
          <ul>
            <li>Teach Python, JavaScript/TypeScript, C++, and Java to students of all levels</li>
            <li>Designed the curriculum for and led a student team contributing to <a href="https://playerpathwayproject.org" target="_blank" rel="noopener">playerpathwayproject.org</a> — a production TypeScript codebase (React/Tailwind frontend, Nest.js/Prisma backend) built in collaboration with Coerver Coaching, an international soccer coaching company</li>
            <li>Currently guiding students building an SAT vocabulary app in React Native</li>
            <li>Promoted to Assistant Manager (Jul 2025 — Apr 2026): onboarded and assessed teachers and launched new program offerings as the branch grew; stepped back to focus on engineering</li>
          </ul>
        </div>
      </div>

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Web Developer / Coding Manager</h3>
            <span class="timeline-meta">Kill That Noise &middot; Remote</span>
          </div>
          <span class="timeline-date">Jun — Oct 2023</span>
          <ul>
            <li>Proposed and led the site's migration from WordPress to Next.js/TypeScript/Tailwind, keeping WordPress as a headless CMS via its REST API</li>
            <li>Promoted to coding manager; coordinated the intern dev team using agile practices and shipped new custom features post-migration</li>
          </ul>
        </div>
      </div>

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Python Data Engineering Intern</h3>
            <span class="timeline-meta">developerDB &middot; Remote</span>
          </div>
          <span class="timeline-date">Sep — Dec 2022</span>
          <ul>
            <li>Maintained and built web scraping pipelines (Python, Selenium) for a recruiting-data product</li>
            <li>Processed and cleaned datasets with pandas; earned a letter of recommendation</li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Skills -->
<section id="skills">
  <div class="container reveal">
    <div class="section-head">
      <span class="section-num">04</span>
      <h2>Skills</h2>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <p class="skills-hint">Skills with an underline are wired to a project — click one to see it in action.</p>
    <div class="skills-grid">
      {orderedSkillGroups.map((group) => (
        <div class="skill-group reveal">
          <h3>{group.title}</h3>
          <div class="skill-items">
            {group.skills.map((skill) =>
              skill.filter && filterableTags.has(skill.filter) ? (
                <button class="skill-filter" data-filter={skill.filter} title={`See projects using ${skill.name}`}>{skill.name}</button>
              ) : (
                <span>{skill.name}</span>
              )
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact">
  <div class="container narrow reveal">
    <div class="section-head">
      <span class="section-num">05</span>
      <h2>Contact</h2>
      <span class="section-rule" aria-hidden="true"></span>
    </div>
    <p class="contact-text">Open to software roles. I'd love to hear about what you're building.</p>
    <div class="contact-links">
      <a href="https://github.com/TTeuber" target="_blank" rel="noopener" class="contact-card">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <a href="https://www.linkedin.com/in/tyler-teuber/" target="_blank" rel="noopener" class="contact-card">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span>LinkedIn</span>
      </a>
      <a href="mailto:tyler.teuber@gmail.com" class="contact-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        <span>Email</span>
      </a>
      <a href={variant.resumePath} class="contact-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
        <span>Résumé</span>
      </a>
    </div>
  </div>
</section>

<Footer />

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Skills → project filter: clicking a filterable skill filters the projects
  // grid (handled inside ProjectsGrid.svelte) and scrolls to it.
  document.querySelectorAll('.skill-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;
      window.dispatchEvent(new CustomEvent('filter-projects', { detail: filter }));
      document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
