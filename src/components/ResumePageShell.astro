---
// Shared shell for resume pages: back-link toolbar, print button, and the
// rendered ResumeSheet. Used by /resume/<variant> and /for/<target>/resume.
import ResumeSheet from './ResumeSheet.astro';

interface Props {
  variant: string; // resume html file name in src/data/resumes/
  backPath: string; // where the toolbar back link points
}

const { variant, backPath } = Astro.props;
---

<div class="resume-page">
  <div class="resume-toolbar">
    <a href={backPath} class="toolbar-link">&larr; tylerteuber.com{backPath === '/' ? '' : backPath}</a>
    <button class="toolbar-btn" id="printBtn">Print / Save as PDF</button>
  </div>

  <ResumeSheet variant={variant} />
</div>

<script>
  document.getElementById('printBtn')?.addEventListener('click', () => window.print());
</script>

<style lang="scss">
  .resume-page {
    min-height: 100vh;
    padding: 40px 24px 80px;
  }

  .resume-toolbar {
    max-width: 800px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .toolbar-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-dim);

    &:hover {
      color: var(--amber);
    }
  }

  .toolbar-btn {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 9px 18px;
    border-radius: 8px;
    border: none;
    background: var(--amber);
    color: var(--bg);
    cursor: pointer;
    transition: background 0.2s ease, box-shadow 0.2s ease;

    &:hover {
      background: var(--amber-bright);
      box-shadow: 0 0 16px var(--amber-glow);
    }
  }

  @media print {
    .resume-page {
      padding: 0;
    }

    .resume-toolbar {
      display: none;
    }
  }
</style>

<style is:global>
  /* Print: strip the dark chrome so only the sheet prints */
  @media print {
    body {
      background: #fff !important;
    }

    body::after {
      display: none !important;
    }
  }
</style>
