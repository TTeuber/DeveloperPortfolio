---
import Layout from '../Layouts/Layout.astro';
---

<Layout title="Tyler Teuber | Frontend Developer">
  <!-- Fixed Navigation -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#hero" class="font-mono text-sm tracking-widest text-teal-400 hover:text-teal-300 transition-colors">
        TT<span class="text-zinc-500">::</span>DEV
      </a>
      <!-- Mobile menu button -->
      <button id="mobile-toggle" class="md:hidden text-zinc-400 hover:text-teal-400 transition-colors" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <ul class="hidden md:flex items-center gap-8 font-mono text-xs tracking-wider">
        <li><a href="#about" class="nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">About</a></li>
        <li><a href="#projects" class="nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Projects</a></li>
        <li><a href="#experience" class="nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Experience</a></li>
        <li><a href="#skills" class="nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Skills</a></li>
        <li><a href="#contact" class="nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Contact</a></li>
      </ul>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800/50 bg-[#0a0a0f]/95 backdrop-blur-md">
      <ul class="flex flex-col items-center gap-4 py-6 font-mono text-xs tracking-wider">
        <li><a href="#about" class="mobile-nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">About</a></li>
        <li><a href="#projects" class="mobile-nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Projects</a></li>
        <li><a href="#experience" class="mobile-nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Experience</a></li>
        <li><a href="#skills" class="mobile-nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Skills</a></li>
        <li><a href="#contact" class="mobile-nav-link text-zinc-400 hover:text-teal-400 transition-colors uppercase">Contact</a></li>
      </ul>
    </div>
  </nav>

  <main class="bg-[#0a0a0f] text-zinc-200 min-h-screen overflow-x-hidden">
    <!-- Grid Background Overlay -->
    <div class="grid-bg fixed inset-0 pointer-events-none z-0"></div>

    <!-- ==================== HERO ==================== -->
    <section id="hero" class="relative min-h-screen flex items-center justify-center px-6 pt-20 z-10">
      <!-- Decorative waveform background -->
      <div class="waveform-bg absolute inset-0 opacity-[0.03] pointer-events-none"></div>

      <div class="max-w-6xl mx-auto w-full grid md:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="reveal">
          <!-- Channel strip label -->
          <div class="flex items-center gap-3 mb-6">
            <div class="vu-bar-mini"></div>
            <span class="font-mono text-xs tracking-[0.3em] text-teal-400/70 uppercase">Channel 01</span>
          </div>

          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[0.9] mb-4">
            <span class="text-zinc-100">Tyler</span><br />
            <span class="text-teal-400">Teuber</span>
          </h1>

          <div class="flex items-center gap-3 my-6">
            <span class="inline-block w-2 h-2 rounded-full bg-teal-400 shadow-[0_0_8px_rgba(45,212,191,0.6)] animate-pulse"></span>
            <span class="font-mono text-sm text-teal-400 tracking-widest uppercase">Frontend Developer</span>
          </div>

          <p class="text-zinc-400 text-lg leading-relaxed max-w-lg mb-8">
            Bridging the worlds of <span class="text-zinc-200 font-medium">audio technology</span> and
            <span class="text-zinc-200 font-medium">modern web development</span> &mdash; building
            interfaces with the precision of a studio mix.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href="#projects" class="group relative inline-flex items-center gap-2 px-6 py-3 bg-teal-500/10 border border-teal-500/30 text-teal-400 font-mono text-sm tracking-wider uppercase hover:bg-teal-500/20 hover:border-teal-400/50 hover:shadow-[0_0_20px_rgba(45,212,191,0.15)] transition-all duration-300">
              <span>View Projects</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="#contact" class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 text-zinc-400 font-mono text-sm tracking-wider uppercase hover:border-zinc-500 hover:text-zinc-200 transition-all duration-300">
              Contact
            </a>
          </div>
        </div>

        <!-- Portrait -->
        <div class="reveal reveal-delay-1 flex justify-center md:justify-end">
          <div class="relative">
            <!-- Decorative frame -->
            <div class="absolute -inset-3 border border-teal-500/10 pointer-events-none"></div>
            <div class="absolute -inset-6 border border-teal-500/5 pointer-events-none"></div>
            <!-- Corner ticks -->
            <div class="absolute -top-6 -left-6 w-4 h-4 border-t border-l border-teal-500/30"></div>
            <div class="absolute -top-6 -right-6 w-4 h-4 border-t border-r border-teal-500/30"></div>
            <div class="absolute -bottom-6 -left-6 w-4 h-4 border-b border-l border-teal-500/30"></div>
            <div class="absolute -bottom-6 -right-6 w-4 h-4 border-b border-r border-teal-500/30"></div>

            <div class="relative w-72 h-80 sm:w-80 sm:h-96 overflow-hidden bg-zinc-900">
              <img src="/Images/Portrait.jpg" alt="Tyler Teuber" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700" />
              <!-- Scanline overlay -->
              <div class="absolute inset-0 bg-gradient-to-b from-transparent via-teal-500/[0.02] to-transparent bg-[length:100%_4px] pointer-events-none scanline-overlay"></div>
            </div>
            <!-- Label -->
            <div class="absolute -bottom-10 left-0 right-0 text-center font-mono text-[10px] tracking-[0.4em] text-zinc-600 uppercase">
              Input &mdash; Stereo
            </div>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce">
        <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">Scroll</span>
        <svg class="w-4 h-4 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7" /></svg>
      </div>
    </section>

    <!-- ==================== ABOUT ==================== -->
    <section id="about" class="relative py-28 px-6 z-10">
      <div class="max-w-5xl mx-auto">
        <div class="reveal flex items-center gap-4 mb-16">
          <div class="section-indicator"></div>
          <h2 class="font-mono text-xs tracking-[0.3em] text-teal-400/70 uppercase">About</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-zinc-800 to-transparent"></div>
        </div>

        <div class="grid md:grid-cols-5 gap-12">
          <div class="md:col-span-3 reveal">
            <h3 class="text-3xl sm:text-4xl font-extrabold text-zinc-100 mb-6 leading-tight">
              Self-taught developer with a <span class="text-teal-400">studio ear</span> for detail
            </h3>
            <div class="space-y-4 text-zinc-400 leading-relaxed">
              <p>
                I'm a self-taught frontend developer who found code through audio. With an
                <span class="text-zinc-200">Economics degree</span> and an <span class="text-zinc-200">Audio Technology minor</span> from
                Western Washington University, I sit at the intersection of analytical thinking,
                creative problem-solving, and technical craft.
              </p>
              <p>
                Since 2022, I've been mentored by a <span class="text-zinc-200">Senior Software Architect</span>,
                accelerating from fundamentals to building production applications. That mentorship
                taught me not just how to write code, but how to <em>think</em> about systems,
                architecture, and maintainability.
              </p>
              <p>
                I leverage <span class="text-zinc-200">Claude Code</span> for agentic development workflows &mdash;
                using AI-assisted tooling to move faster while maintaining the precision and
                intentionality that comes from a background in audio engineering.
              </p>
            </div>
          </div>

          <!-- Stats / Info Panel -->
          <div class="md:col-span-2 reveal reveal-delay-1 space-y-4">
            <div class="stat-panel">
              <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">Education</span>
              <p class="text-zinc-200 text-sm mt-1">B.A. Economics</p>
              <p class="text-zinc-400 text-xs">Audio Technology Minor</p>
              <p class="text-zinc-500 text-xs">Western Washington University</p>
            </div>
            <div class="stat-panel">
              <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">Mentorship</span>
              <p class="text-zinc-200 text-sm mt-1">Senior Software Architect</p>
              <p class="text-zinc-400 text-xs">Since 2022 &mdash; Present</p>
            </div>
            <div class="stat-panel">
              <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">Dev Workflow</span>
              <p class="text-zinc-200 text-sm mt-1">Claude Code</p>
              <p class="text-zinc-400 text-xs">Agentic AI-assisted development</p>
            </div>
            <div class="stat-panel">
              <span class="font-mono text-[10px] tracking-widest text-zinc-600 uppercase">Focus</span>
              <p class="text-zinc-200 text-sm mt-1">Audio &times; Web</p>
              <p class="text-zinc-400 text-xs">Where sound meets interface</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PROJECTS ==================== -->
    <section id="projects" class="relative py-28 px-6 z-10">
      <div class="max-w-6xl mx-auto">
        <div class="reveal flex items-center gap-4 mb-16">
          <div class="section-indicator"></div>
          <h2 class="font-mono text-xs tracking-[0.3em] text-teal-400/70 uppercase">Projects</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-zinc-800 to-transparent"></div>
        </div>

        <!-- Project 1: Synthesizer VST -->
        <div class="project-card reveal mb-16">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="relative overflow-hidden bg-zinc-950 aspect-video md:aspect-auto">
              <img src="/Images/Synth/Synth.png" alt="Synthesizer VST Plugin" class="w-full h-full object-cover object-center opacity-90 hover:opacity-100 transition-opacity duration-500" />
              <div class="absolute top-3 left-3 flex items-center gap-2">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-teal-400 shadow-[0_0_6px_rgba(45,212,191,0.6)]"></span>
                <span class="font-mono text-[10px] tracking-widest text-teal-400/60 uppercase">Project 01</span>
              </div>
            </div>
            <div class="p-8 sm:p-10 flex flex-col justify-center">
              <h3 class="text-2xl sm:text-3xl font-extrabold text-zinc-100 mb-3">Synthesizer VST</h3>
              <p class="text-zinc-400 leading-relaxed mb-6">
                A subtractive synthesizer plugin with a gesture-based UI and a sound engine inspired
                by the classic Juno. Built in C++ with the JUCE framework, featuring a modulation
                matrix, multi-effects rack, multiple oscillators, and an innovative "Modulation Mode"
                UX for intuitive sound design.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="tech-tag">C++</span>
                <span class="tech-tag">JUCE</span>
                <span class="tech-tag">DSP</span>
              </div>
              <ul class="space-y-2 text-sm text-zinc-500 font-mono">
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Modulation Matrix</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Multi-Effects Rack</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Multiple Oscillators</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Gesture-Based "Modulation Mode" UX</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Project 2: Self-Control Content Blocker -->
        <div class="project-card reveal mb-16">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="p-8 sm:p-10 flex flex-col justify-center order-2 md:order-1">
              <h3 class="text-2xl sm:text-3xl font-extrabold text-zinc-100 mb-3">Self-Control Content Blocker</h3>
              <p class="text-zinc-400 leading-relaxed mb-6">
                A bypass-resistant website and application blocker engineered for Arch Linux with
                Hyprland. Combines a Python backend daemon with a TypeScript/React/Tailwind frontend,
                using systemd services and Flask to create an enforcement layer that's genuinely
                difficult to circumvent.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="tech-tag">Python</span>
                <span class="tech-tag">TypeScript</span>
                <span class="tech-tag">React</span>
                <span class="tech-tag">Flask</span>
              </div>
              <ul class="space-y-2 text-sm text-zinc-500 font-mono">
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Systemd Daemon + Flask Backend</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> React/Tailwind Frontend</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Chrome Extension</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Bypass-Resistant Architecture</li>
              </ul>
            </div>
            <div class="relative overflow-hidden bg-zinc-950 aspect-video md:aspect-auto order-1 md:order-2">
              <img src="/Images/Blocker/WebsiteBlocker.png" alt="Self-Control Content Blocker" class="w-full h-full object-cover object-center opacity-90 hover:opacity-100 transition-opacity duration-500" />
              <div class="absolute top-3 right-3 flex items-center gap-2">
                <span class="font-mono text-[10px] tracking-widest text-teal-400/60 uppercase">Project 02</span>
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-teal-400 shadow-[0_0_6px_rgba(45,212,191,0.6)]"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Project 3: Sermon Slide Generator -->
        <div class="project-card reveal">
          <div class="grid md:grid-cols-2 gap-0">
            <div class="relative overflow-hidden bg-zinc-950 aspect-video md:aspect-auto">
              <img src="/Images/SermonSlides/SermonSlidesGenerator.png" alt="Sermon Slide Generator" class="w-full h-full object-cover object-center opacity-90 hover:opacity-100 transition-opacity duration-500" />
              <div class="absolute top-3 left-3 flex items-center gap-2">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-teal-400 shadow-[0_0_6px_rgba(45,212,191,0.6)]"></span>
                <span class="font-mono text-[10px] tracking-widest text-teal-400/60 uppercase">Project 03</span>
              </div>
            </div>
            <div class="p-8 sm:p-10 flex flex-col justify-center">
              <h3 class="text-2xl sm:text-3xl font-extrabold text-zinc-100 mb-3">Sermon Slide Generator</h3>
              <p class="text-zinc-400 leading-relaxed mb-6">
                A Python automation tool built for church staff at The Redemption Church.
                Scrapes sermon content from the web and generates formatted PDF slide decks
                automatically, replacing a tedious manual workflow with a single command.
              </p>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="tech-tag">Python</span>
                <span class="tech-tag">HTML/CSS/JS</span>
                <span class="tech-tag">Web Scraping</span>
              </div>
              <ul class="space-y-2 text-sm text-zinc-500 font-mono">
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Automated Web Scraping</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> PDF Generation Pipeline</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> HTML/CSS/JS Frontend</li>
                <li class="flex items-center gap-2"><span class="text-teal-400/60">&#9656;</span> Built for The Redemption Church</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== EXPERIENCE ==================== -->
    <section id="experience" class="relative py-28 px-6 z-10">
      <div class="max-w-4xl mx-auto">
        <div class="reveal flex items-center gap-4 mb-16">
          <div class="section-indicator"></div>
          <h2 class="font-mono text-xs tracking-[0.3em] text-teal-400/70 uppercase">Experience</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-zinc-800 to-transparent"></div>
        </div>

        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-teal-500/40 via-zinc-800 to-transparent"></div>

          <!-- Experience 1 -->
          <div class="timeline-item reveal mb-14">
            <div class="flex gap-6">
              <div class="relative flex-shrink-0 mt-1.5">
                <div class="w-[15px] h-[15px] rounded-full border-2 border-teal-400 bg-[#0a0a0f] shadow-[0_0_8px_rgba(45,212,191,0.3)]"></div>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
                  <h3 class="text-xl font-bold text-zinc-100">Coding Mind</h3>
                  <span class="font-mono text-xs text-teal-400/60 tracking-wider">Aug 2024 &mdash; Present</span>
                </div>
                <p class="font-mono text-sm text-zinc-400 mb-1">Teacher / Assistant Manager</p>
                <p class="font-mono text-xs text-zinc-600 mb-4">Redmond, WA</p>
                <ul class="space-y-2 text-sm text-zinc-400 leading-relaxed">
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Teaching Python, JavaScript, and C++ to students across skill levels</li>
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Led curriculum and development for <span class="text-zinc-200">playerpathwayproject.org</span> &mdash; a full-stack application built with TypeScript, React, Tailwind CSS, Nest.js, and Prisma</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Experience 2 -->
          <div class="timeline-item reveal mb-14">
            <div class="flex gap-6">
              <div class="relative flex-shrink-0 mt-1.5">
                <div class="w-[15px] h-[15px] rounded-full border-2 border-zinc-600 bg-[#0a0a0f]"></div>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
                  <h3 class="text-xl font-bold text-zinc-100">Kill That Noise</h3>
                  <span class="font-mono text-xs text-teal-400/60 tracking-wider">Jun &mdash; Oct 2023</span>
                </div>
                <p class="font-mono text-sm text-zinc-400 mb-1">Web Development Intern</p>
                <p class="font-mono text-xs text-zinc-600 mb-4">Remote</p>
                <ul class="space-y-2 text-sm text-zinc-400 leading-relaxed">
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Led a team of 5 interns migrating a WordPress site to <span class="text-zinc-200">Next.js</span></li>
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Managed project using Agile methodology with sprint planning and retrospectives</li>
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Integrated WordPress REST API for content management</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Experience 3 -->
          <div class="timeline-item reveal">
            <div class="flex gap-6">
              <div class="relative flex-shrink-0 mt-1.5">
                <div class="w-[15px] h-[15px] rounded-full border-2 border-zinc-600 bg-[#0a0a0f]"></div>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-2">
                  <h3 class="text-xl font-bold text-zinc-100">DeveloperDB</h3>
                  <span class="font-mono text-xs text-teal-400/60 tracking-wider">Sep &mdash; Dec 2022</span>
                </div>
                <p class="font-mono text-sm text-zinc-400 mb-1">Data Engineering Intern</p>
                <p class="font-mono text-xs text-zinc-600 mb-4">Remote</p>
                <ul class="space-y-2 text-sm text-zinc-400 leading-relaxed">
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Built Selenium-based scrapers to collect <span class="text-zinc-200">10,000+</span> LinkedIn developer profiles</li>
                  <li class="flex gap-2"><span class="text-teal-400/50 mt-0.5 flex-shrink-0">&#9656;</span> Processed and cleaned data using Pandas for analysis and reporting</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SKILLS ==================== -->
    <section id="skills" class="relative py-28 px-6 z-10">
      <div class="max-w-5xl mx-auto">
        <div class="reveal flex items-center gap-4 mb-16">
          <div class="section-indicator"></div>
          <h2 class="font-mono text-xs tracking-[0.3em] text-teal-400/70 uppercase">Skills</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-zinc-800 to-transparent"></div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Frontend -->
          <div class="skill-group reveal">
            <div class="flex items-center gap-2 mb-5">
              <div class="eq-bars">
                <span></span><span></span><span></span><span></span>
              </div>
              <h3 class="font-mono text-xs tracking-[0.2em] text-teal-400/80 uppercase">Frontend</h3>
            </div>
            <ul class="space-y-2.5">
              <li class="skill-item">React</li>
              <li class="skill-item">TypeScript</li>
              <li class="skill-item">Next.js</li>
              <li class="skill-item">Tailwind CSS</li>
              <li class="skill-item">HTML/CSS</li>
              <li class="skill-item">Svelte</li>
            </ul>
          </div>

          <!-- Backend -->
          <div class="skill-group reveal reveal-delay-1">
            <div class="flex items-center gap-2 mb-5">
              <div class="eq-bars">
                <span></span><span></span><span></span><span></span>
