---
import Layout from '../Layouts/Layout.astro';
---

<Layout title="Tyler Teuber — Portfolio Design Picker">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #0c0c0c;
      color: #fafafa;
      min-height: 100vh;
    }
    .font-mono {
      font-family: 'JetBrains Mono', monospace;
    }
    .card {
      background: #161616;
      border: 1px solid #222;
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.3s ease, box-shadow 0.4s ease;
    }
    .card:hover {
      transform: translateY(-6px);
      border-color: #444;
      box-shadow: 0 20px 60px -12px rgba(255, 255, 255, 0.04);
    }
    .card-accent {
      height: 3px;
      border-radius: 2px;
      transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
      width: 40px;
    }
    .card:hover .card-accent {
      width: 100%;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-in {
      animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
  </style>

  <main class="max-w-5xl mx-auto px-6 py-20">
    <div class="animate-in mb-16 text-center">
      <p class="font-mono text-xs tracking-widest uppercase text-neutral-500 mb-4">Portfolio Designs</p>
      <h1 class="text-4xl sm:text-5xl font-light tracking-tight mb-4">
        Pick a <span class="font-bold">Direction</span>
      </h1>
      <p class="text-neutral-500 font-light max-w-md mx-auto">
        Five design versions to choose from. Click any card to preview.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- V1 -->
      <a href="/v1" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.1s">
        <div class="card-accent bg-slate-500 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">Version 01</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Clean Minimal</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Swiss-inspired precision. White theme, slate blue accent, strong typography hierarchy, generous whitespace.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">light</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">minimal</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">typographic</span>
        </div>
      </a>

      <!-- V2 -->
      <a href="/v2" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.15s">
        <div class="card-accent bg-teal-500 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">Version 02</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Dark Studio</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          DAW-inspired dark interface. Teal/cyan accents, audio waveform elements, studio software aesthetic.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">dark</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">audio</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">technical</span>
        </div>
      </a>

      <!-- V3 -->
      <a href="/v3" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.2s">
        <div class="card-accent bg-gradient-to-r from-purple-500 to-blue-500 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">Version 03</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Bold Gradient</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Vibrant purple-to-blue gradients, bold typography, glass-morphism cards, energetic and modern.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">vibrant</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">gradient</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">bold</span>
        </div>
      </a>

      <!-- V4 -->
      <a href="/v4" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.25s">
        <div class="card-accent bg-[#E54D2E] mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">Version 04</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Editorial Grid</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Magazine-style bento grid layout. Asymmetric, warm neutrals with vermillion accent, editorial typography.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">editorial</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">bento</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">asymmetric</span>
        </div>
      </a>

      <!-- V5 -->
      <a href="/v5" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.3s">
        <div class="card-accent bg-amber-500 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">Version 05</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Interactive Showcase</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Most technically impressive. Svelte interactivity, radar charts, 3D tilt cards, scroll animations, mouse effects.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">interactive</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">svelte</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">animated</span>
        </div>
      </a>
    </div>

    <!-- MultiTracks Section -->
    <div class="animate-in mt-20 mb-12 text-center" style="animation-delay: 0.4s">
      <div class="w-12 h-px bg-neutral-700 mx-auto mb-8"></div>
      <p class="font-mono text-xs tracking-widest uppercase text-neutral-500 mb-4">MultiTracks Application</p>
      <h2 class="text-2xl sm:text-3xl font-light tracking-tight mb-3">
        Tailored for <span class="font-bold">MultiTracks.com</span>
      </h2>
      <p class="text-neutral-500 font-light max-w-md mx-auto text-sm">
        Customized versions with church tech focus, personal MultiTracks story, and job-specific messaging.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- MT V1 -->
      <a href="/multitracks/v1" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.45s">
        <div class="card-accent bg-teal-500 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">MultiTracks 01</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Studio + Mission</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Dark studio aesthetic with "Why MultiTracks" section. Teal accents, audio elements, church tech focus.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">dark</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">studio</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">narrative</span>
        </div>
      </a>

      <!-- MT V2 -->
      <a href="/multitracks/v2" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.5s">
        <div class="card-accent bg-amber-600 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">MultiTracks 02</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Warm Dark</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Warm amber accents on charcoal. "What I Bring" callout cards matching job requirements. Team-focused.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">warm</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">amber</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">callouts</span>
        </div>
      </a>

      <!-- MT V3 -->
      <a href="/multitracks/v3" class="card rounded-lg p-6 block animate-in" style="animation-delay: 0.55s">
        <div class="card-accent bg-indigo-600 mb-5"></div>
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-neutral-500">MultiTracks 03</span>
        <h2 class="text-xl font-semibold mt-2 mb-2">Refined Light</h2>
        <p class="text-sm text-neutral-500 font-light leading-relaxed">
          Premium light theme with personal cover letter. Apple-level clarity, indigo accents, narrative approach.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-4">
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">light</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">refined</span>
          <span class="font-mono text-[0.5625rem] px-2 py-0.5 bg-neutral-800 text-neutral-400 rounded">letter</span>
        </div>
      </a>
    </div>
  </main>
</Layout>
