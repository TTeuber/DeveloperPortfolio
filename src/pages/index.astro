---
import Layout from '../Layouts/Layout.astro';
import ProjectsGrid from '../components/ProjectsGrid.svelte';
import { filterableTags } from '../data/projects.js';
import { skillGroups } from '../data/skills.js';
---

<Layout title="Tyler Teuber | Software Developer" description="Software developer building thoughtful, well-crafted software.">

<!-- Fixed Navigation -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="#hero" class="nav-logo">TT</a>
    <div class="nav-links" id="navLinks">
      <a href="#projects">Projects</a>
      <a href="#experience">Experience</a>
      <a href="#skills">Skills</a>
      <a href="#contact">Contact</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div class="mobile-menu" id="mobileMenu">
  <a href="#projects" class="mobile-link">Projects</a>
  <a href="#experience" class="mobile-link">Experience</a>
  <a href="#skills" class="mobile-link">Skills</a>
  <a href="#contact" class="mobile-link">Contact</a>
</div>

<!-- Hero -->
<section id="hero">
  <div class="hero-content reveal">
    <span class="label">Software Developer</span>
    <h1>Tyler Teuber</h1>
    <p class="subtitle">Building thoughtful, well-crafted software.</p>
    <p class="tagline">From hand-written C++ audio DSP to full-stack web apps — I like building across the whole stack.</p>
    <div class="portrait-wrap">
      <img src="/Images/Portrait.jpg" alt="Tyler Teuber" class="portrait" />
    </div>
    <div class="hero-ctas">
      <a href="#projects" class="btn btn-primary">See My Work</a>
      <a href="#contact" class="btn btn-secondary">Get in Touch</a>
    </div>
  </div>
</section>

<!-- Projects -->
<section id="projects">
  <div class="container reveal">
    <span class="section-label">Selected Work</span>
    <h2>Projects</h2>
    <ProjectsGrid client:load />
  </div>
</section>

<!-- Experience -->
<section id="experience">
  <div class="container reveal">
    <span class="section-label">Professional Background</span>
    <h2>Experience</h2>
    <div class="timeline">

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Teacher / Assistant Manager</h3>
            <span class="timeline-meta">Coding Mind &middot; Redmond, WA</span>
          </div>
          <span class="timeline-date">Aug 2024 — Present</span>
          <ul>
            <li>Teach Python, JavaScript, and C++ to students of varying skill levels</li>
            <li>Led teaching and student development of <a href="https://playerpathwayproject.org" target="_blank" rel="noopener">playerpathwayproject.org</a> using TypeScript, React, Tailwind CSS on the frontend with Nest.js and Prisma on the backend</li>
          </ul>
        </div>
      </div>

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Web Developer Intern</h3>
            <span class="timeline-meta">Kill That Noise &middot; Remote</span>
          </div>
          <span class="timeline-date">Jun — Oct 2023</span>
          <ul>
            <li>Led a team of 5 interns through a WordPress-to-Next.js migration</li>
            <li>Worked in an Agile environment with sprint planning and code reviews</li>
            <li>Integrated REST APIs and improved site performance</li>
          </ul>
        </div>
      </div>

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Data Engineering Intern</h3>
            <span class="timeline-meta">DeveloperDB &middot; Remote</span>
          </div>
          <span class="timeline-date">Sep — Dec 2022</span>
          <ul>
            <li>Built automated scraping pipelines with Selenium to collect 10,000+ developer profiles</li>
            <li>Processed and cleaned datasets using Pandas for analysis and reporting</li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- Skills -->
<section id="skills">
  <div class="container reveal">
    <span class="section-label">Technical Toolkit</span>
    <h2>Skills</h2>
    <p class="skills-hint">Skills with an underline are used in a project — click one to see it in action.</p>
    <div class="skills-grid compact">
      {skillGroups.map((group) => (
        <div class="skill-group reveal">
          <h3>{group.title}</h3>
          <div class="skill-items">
            {group.skills.map((skill) =>
              skill.filter && filterableTags.has(skill.filter) ? (
                <button class="skill-filter" data-filter={skill.filter} title={`See projects using ${skill.name}`}>{skill.name}</button>
              ) : (
                <span>{skill.name}</span>
              )
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact">
  <div class="container narrow reveal">
    <span class="section-label">Get in Touch</span>
    <h2>Let's Connect</h2>
    <p class="contact-text">Open to software roles. I'd love to hear about what you're building.</p>
    <div class="contact-links">
      <a href="https://github.com/TTeuber" target="_blank" rel="noopener" class="contact-card">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <a href="https://www.linkedin.com/in/tyler-teuber/" target="_blank" rel="noopener" class="contact-card">
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span>LinkedIn</span>
      </a>
      <a href="mailto:tyler.teuber@gmail.com" class="contact-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        <span>Email</span>
      </a>
    </div>
  </div>
</section>

<footer>
  <p>&copy; 2026 Tyler Teuber. Built with Astro & crafted with care.</p>
</footer>

</Layout>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  // Mobile menu
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu?.classList.toggle('open');
    document.body.style.overflow = mobileMenu?.classList.contains('open') ? 'hidden' : '';
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      mobileMenu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Skills → project filter: clicking a filterable skill filters the projects
  // grid (handled inside ProjectsGrid.svelte) and scrolls to it.
  document.querySelectorAll('.skill-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;
      window.dispatchEvent(new CustomEvent('filter-projects', { detail: filter }));
      document.getElementById('projects')?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
