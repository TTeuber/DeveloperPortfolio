---
import Layout from '../Layouts/Layout.astro';
---

<Layout title="Tyler Teuber | Frontend Developer" description="Bold gradient portfolio — frontend developer bridging audio technology and web development.">

<!-- FIXED NAV -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 translate-y-[-100%]">
  <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between backdrop-blur-xl bg-[#1a103d]/70 border-b border-white/10 rounded-b-2xl">
    <a href="#hero" class="font-[Inter] font-900 text-xl bg-gradient-to-r from-purple-400 via-fuchsia-400 to-blue-400 bg-clip-text text-transparent">TT</a>
    <div class="hidden md:flex items-center gap-8">
      <a href="#about" class="nav-link text-sm font-medium text-white/70 hover:text-white transition-colors">About</a>
      <a href="#projects" class="nav-link text-sm font-medium text-white/70 hover:text-white transition-colors">Projects</a>
      <a href="#experience" class="nav-link text-sm font-medium text-white/70 hover:text-white transition-colors">Experience</a>
      <a href="#skills" class="nav-link text-sm font-medium text-white/70 hover:text-white transition-colors">Skills</a>
      <a href="#contact" class="nav-link text-sm font-medium text-black bg-gradient-to-r from-purple-400 to-blue-400 px-4 py-2 rounded-full hover:shadow-[0_0_24px_rgba(168,85,247,0.5)] transition-all duration-300">Contact</a>
    </div>
    <button id="mobile-toggle" class="md:hidden text-white/80 hover:text-white" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden backdrop-blur-xl bg-[#1a103d]/90 border-b border-white/10 px-6 py-4 flex-col gap-4">
    <a href="#about" class="block text-white/70 hover:text-white py-2">About</a>
    <a href="#projects" class="block text-white/70 hover:text-white py-2">Projects</a>
    <a href="#experience" class="block text-white/70 hover:text-white py-2">Experience</a>
    <a href="#skills" class="block text-white/70 hover:text-white py-2">Skills</a>
    <a href="#contact" class="block text-white/70 hover:text-white py-2">Contact</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0d0628]">
  <!-- Gradient mesh blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="blob blob-1 absolute w-[700px] h-[700px] rounded-full bg-purple-600/30 blur-[120px] -top-40 -left-40"></div>
    <div class="blob blob-2 absolute w-[600px] h-[600px] rounded-full bg-indigo-500/25 blur-[100px] top-1/3 right-[-10%]"></div>
    <div class="blob blob-3 absolute w-[500px] h-[500px] rounded-full bg-blue-600/20 blur-[120px] bottom-[-10%] left-1/4"></div>
    <div class="blob blob-4 absolute w-[400px] h-[400px] rounded-full bg-fuchsia-500/20 blur-[80px] top-[60%] right-1/4"></div>
  </div>
  <!-- Grid overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-20 py-24">
    <div class="flex-1 text-center lg:text-left reveal-up">
      <p class="font-[JetBrains_Mono] text-sm md:text-base text-purple-300/80 mb-4 tracking-widest uppercase">Frontend Developer</p>
      <h1 class="font-[Inter] font-900 text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] text-white mb-6">
        Tyler<br/>
        <span class="bg-gradient-to-r from-purple-400 via-fuchsia-400 to-blue-400 bg-clip-text text-transparent">Teuber</span>
      </h1>
      <p class="text-lg md:text-xl text-white/60 max-w-lg mx-auto lg:mx-0 mb-10 leading-relaxed">
        Bridging audio technology and web development — crafting immersive digital experiences where sound and code converge.
      </p>
      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <a href="#projects" class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-black bg-gradient-to-r from-purple-400 via-fuchsia-400 to-blue-400 hover:shadow-[0_0_40px_rgba(168,85,247,0.4)] transition-all duration-300 hover:scale-105">
          View Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white border border-white/20 hover:border-purple-400/60 hover:bg-white/5 transition-all duration-300 hover:scale-105 hover:shadow-[0_0_30px_rgba(168,85,247,0.15)]">
          Get in Touch
        </a>
      </div>
    </div>
    <div class="flex-shrink-0 reveal-up" style="animation-delay:0.2s">
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-br from-purple-500 via-fuchsia-500 to-blue-500 rounded-full blur-xl opacity-50 animate-pulse-slow"></div>
        <div class="relative w-56 h-56 md:w-72 md:h-72 rounded-full overflow-hidden ring-4 ring-white/10 shadow-2xl">
          <img src="/Images/Portrait.jpg" alt="Tyler Teuber" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/30 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </div>
</section>

<!-- ABOUT -->
<section id="about" class="relative py-28 md:py-36 bg-[#0f0833] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="blob absolute w-[500px] h-[500px] rounded-full bg-indigo-600/15 blur-[120px] -top-20 right-[-10%]"></div>
    <div class="blob absolute w-[400px] h-[400px] rounded-full bg-purple-500/10 blur-[100px] bottom-0 left-[-5%]"></div>
  </div>
  <div class="relative z-10 max-w-5xl mx-auto px-6">
    <div class="text-center mb-16 reveal-up">
      <p class="font-[JetBrains_Mono] text-sm text-purple-400 tracking-widest uppercase mb-3">Who I Am</p>
      <h2 class="font-[Inter] font-900 text-4xl md:text-5xl lg:text-6xl text-white">About Me</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <div class="glass-card rounded-2xl p-8 reveal-up" style="animation-delay:0.1s">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        </div>
        <h3 class="font-[Inter] font-800 text-xl text-white mb-3">Self-Taught Developer</h3>
        <p class="text-white/60 leading-relaxed">A self-taught developer mentored by a Senior Software Architect since 2022. I combine relentless curiosity with hands-on practice, using tools like Claude Code for agentic development to accelerate my workflow and push creative boundaries.</p>
      </div>
      <div class="glass-card rounded-2xl p-8 reveal-up" style="animation-delay:0.2s">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-fuchsia-500 to-purple-500 flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.1-1.34 2-3 2s-3-.9-3-2 1.34-2 3-2 3 .9 3 2zm12-3c0 1.1-1.34 2-3 2s-3-.9-3-2 1.34-2 3-2 3 .9 3 2z"/></svg>
        </div>
        <h3 class="font-[Inter] font-800 text-xl text-white mb-3">Audio Meets Code</h3>
        <p class="text-white/60 leading-relaxed">Holding an Economics degree with an Audio Technology minor from Western Washington University, I thrive at the intersection of sound and software — building synthesizers, audio tools, and expressive interfaces that blur the line between music and technology.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects" class="relative py-28 md:py-36 bg-[#f5f0ff] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute w-[600px] h-[600px] rounded-full bg-purple-200/40 blur-[120px] -top-40 -right-40"></div>
    <div class="absolute w-[500px] h-[500px] rounded-full bg-indigo-200/30 blur-[100px] bottom-[-10%] left-[-10%]"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 reveal-up">
      <p class="font-[JetBrains_Mono] text-sm text-purple-600 tracking-widest uppercase mb-3">Selected Work</p>
      <h2 class="font-[Inter] font-900 text-4xl md:text-5xl lg:text-6xl text-gray-900">Projects</h2>
    </div>

    <!-- Project 1 — Synthesizer -->
    <div class="project-card group mb-12 reveal-up" style="animation-delay:0.1s">
      <div class="rounded-3xl overflow-hidden bg-white shadow-xl shadow-purple-200/30 border border-purple-100/50 hover:shadow-2xl hover:shadow-purple-300/30 transition-all duration-500 hover:-translate-y-1">
        <div class="relative overflow-hidden">
          <img src="/Images/Synth/Synth.png" alt="Synthesizer VST" class="w-full h-64 md:h-80 object-cover transition-transform duration-700 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          <div class="absolute bottom-4 left-6 flex gap-2">
            <span class="tech-pill">C++</span>
            <span class="tech-pill">JUCE</span>
            <span class="tech-pill">DSP</span>
          </div>
        </div>
        <div class="p-8">
          <h3 class="font-[Inter] font-800 text-2xl md:text-3xl text-gray-900 mb-3">Synthesizer VST</h3>
          <p class="text-gray-600 leading-relaxed mb-5">A subtractive synthesizer plugin with a gesture-based UI inspired by the Juno sound engine. Features a Modulation Matrix, built-in effects, multiple oscillators, and a unique "Modulation Mode" UX paradigm for expressive sound design.</p>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Modulation Matrix</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Effects Chain</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Multiple Oscillators</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Modulation Mode UX</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 2 — Content Blocker -->
    <div class="project-card group mb-12 reveal-up" style="animation-delay:0.2s">
      <div class="rounded-3xl overflow-hidden bg-white shadow-xl shadow-purple-200/30 border border-purple-100/50 hover:shadow-2xl hover:shadow-purple-300/30 transition-all duration-500 hover:-translate-y-1">
        <div class="relative overflow-hidden">
          <img src="/Images/Blocker/WebsiteBlocker.png" alt="Self-Control Content Blocker" class="w-full h-64 md:h-80 object-cover transition-transform duration-700 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          <div class="absolute bottom-4 left-6 flex gap-2">
            <span class="tech-pill">Python</span>
            <span class="tech-pill">TypeScript</span>
            <span class="tech-pill">React</span>
            <span class="tech-pill">Flask</span>
          </div>
        </div>
        <div class="p-8">
          <h3 class="font-[Inter] font-800 text-2xl md:text-3xl text-gray-900 mb-3">Self-Control Content Blocker</h3>
          <p class="text-gray-600 leading-relaxed mb-5">A bypass-resistant website and app blocking system built for Arch Linux with Hyprland. Features a Python backend with Systemd daemon and Flask API, a TypeScript/React/Tailwind frontend, and a Chrome extension for comprehensive blocking coverage.</p>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Bypass-Resistant</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Systemd Daemon</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Chrome Extension</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Project 3 — Sermon Slides -->
    <div class="project-card group reveal-up" style="animation-delay:0.3s">
      <div class="rounded-3xl overflow-hidden bg-white shadow-xl shadow-purple-200/30 border border-purple-100/50 hover:shadow-2xl hover:shadow-purple-300/30 transition-all duration-500 hover:-translate-y-1">
        <div class="relative overflow-hidden">
          <img src="/Images/SermonSlides/SermonSlidesGenerator.png" alt="Sermon Slide Generator" class="w-full h-64 md:h-80 object-cover transition-transform duration-700 group-hover:scale-105"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
          <div class="absolute bottom-4 left-6 flex gap-2">
            <span class="tech-pill">Python</span>
            <span class="tech-pill">HTML/CSS/JS</span>
            <span class="tech-pill">Web Scraping</span>
          </div>
        </div>
        <div class="p-8">
          <h3 class="font-[Inter] font-800 text-2xl md:text-3xl text-gray-900 mb-3">Sermon Slide Generator</h3>
          <p class="text-gray-600 leading-relaxed mb-5">A Python automation tool built for church staff at The Redemption Church. Combines web scraping with PDF generation to streamline weekly sermon slide creation, featuring an HTML/CSS/JS frontend for intuitive operation.</p>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Automated Pipeline</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>PDF Generation</span>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-purple-700"><span class="w-1.5 h-1.5 rounded-full bg-purple-500"></span>Web Scraping</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EXPERIENCE -->
<section id="experience" class="relative py-28 md:py-36 bg-[#0d0628] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="blob absolute w-[500px] h-[500px] rounded-full bg-purple-600/15 blur-[120px] top-1/4 -left-40"></div>
    <div class="blob absolute w-[400px] h-[400px] rounded-full bg-blue-600/10 blur-[100px] bottom-0 right-[-5%]"></div>
  </div>
  <div class="relative z-10 max-w-4xl mx-auto px-6">
    <div class="text-center mb-16 reveal-up">
      <p class="font-[JetBrains_Mono] text-sm text-purple-400 tracking-widest uppercase mb-3">Career Path</p>
      <h2 class="font-[Inter] font-900 text-4xl md:text-5xl lg:text-6xl text-white">Experience</h2>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-6 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-purple-500 via-fuchsia-500 to-blue-500"></div>

      <!-- Coding Mind -->
      <div class="relative pl-16 md:pl-20 pb-16 reveal-up" style="animation-delay:0.1s">
        <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 rounded-full bg-gradient-to-br from-purple-400 to-fuchsia-400 ring-4 ring-[#0d0628] shadow-[0_0_12px_rgba(168,85,247,0.5)]"></div>
        <div class="glass-card rounded-2xl p-6 md:p-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
            <h3 class="font-[Inter] font-800 text-xl text-white">Teacher / Assistant Manager</h3>
            <span class="font-[JetBrains_Mono] text-sm text-purple-300">Aug 2024 - Present</span>
          </div>
          <p class="font-semibold text-purple-400 mb-3">Coding Mind <span class="text-white/40">|</span> <span class="text-white/50 font-normal">Redmond, WA</span></p>
          <p class="text-white/60 leading-relaxed">Teaching Python, JavaScript, and C++ to students of all levels. Led curriculum development for <span class="font-[JetBrains_Mono] text-purple-300 text-sm">playerpathwayproject.org</span> — a full-stack application built with TypeScript, React, Tailwind CSS, Nest.js, and Prisma.</p>
        </div>
      </div>

      <!-- Kill That Noise -->
      <div class="relative pl-16 md:pl-20 pb-16 reveal-up" style="animation-delay:0.2s">
        <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 rounded-full bg-gradient-to-br from-fuchsia-400 to-indigo-400 ring-4 ring-[#0d0628] shadow-[0_0_12px_rgba(168,85,247,0.4)]"></div>
        <div class="glass-card rounded-2xl p-6 md:p-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
            <h3 class="font-[Inter] font-800 text-xl text-white">Web Dev Intern</h3>
            <span class="font-[JetBrains_Mono] text-sm text-purple-300">Jun - Oct 2023</span>
          </div>
          <p class="font-semibold text-purple-400 mb-3">Kill That Noise <span class="text-white/40">|</span> <span class="text-white/50 font-normal">Remote</span></p>
          <p class="text-white/60 leading-relaxed">Led a team of 5 interns migrating a WordPress site to Next.js. Practiced Agile methodologies and integrated WordPress REST API for seamless content management during the transition.</p>
        </div>
      </div>

      <!-- DeveloperDB -->
      <div class="relative pl-16 md:pl-20 reveal-up" style="animation-delay:0.3s">
        <div class="absolute left-[18px] md:left-[26px] top-1 w-4 h-4 rounded-full bg-gradient-to-br from-indigo-400 to-blue-400 ring-4 ring-[#0d0628] shadow-[0_0_12px_rgba(99,102,241,0.4)]"></div>
        <div class="glass-card rounded-2xl p-6 md:p-8">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-3">
            <h3 class="font-[Inter] font-800 text-xl text-white">Data Engineering Intern</h3>
            <span class="font-[JetBrains_Mono] text-sm text-purple-300">Sep - Dec 2022</span>
          </div>
          <p class="font-semibold text-purple-400 mb-3">DeveloperDB <span class="text-white/40">|</span> <span class="text-white/50 font-normal">Remote</span></p>
          <p class="text-white/60 leading-relaxed">Built Selenium-based scraping pipelines to collect 10,000+ LinkedIn profiles. Processed and cleaned data using Pandas for analytics and lead generation workflows.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section id="skills" class="relative py-28 md:py-36 bg-[#f5f0ff] overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute w-[500px] h-[500px] rounded-full bg-purple-200/40 blur-[120px] top-[-10%] left-[-10%]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-indigo-200/30 blur-[80px] bottom-[-10%] right-[-5%]"></div>
  </div>
  <div class="relative z-10 max-w-5xl mx-auto px-6">
    <div class="text-center mb-16 reveal-up">
      <p class="font-[JetBrains_Mono] text-sm text-purple-600 tracking-widest uppercase mb-3">Tech Stack</p>
      <h2 class="font-[Inter] font-900 text-4xl md:text-5xl lg:text-6xl text-gray-900">Skills</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Frontend -->
      <div class="skill-category reveal-up" style="animation-delay:0.1s">
        <div class="rounded-2xl bg-white p-6 shadow-lg shadow-purple-100/50 border border-purple-100/30 hover:shadow-xl hover:shadow-purple-200/40 transition-all duration-300 hover:-translate-y-1 h-full">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-purple-500 to-indigo-500 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-[Inter] font-800 text-lg text-gray-900 mb-3">Frontend</h3>
          <div class="flex flex-wrap gap-2">
            <span class="skill-tag">React</span>
            <span class="skill-tag">TypeScript</span>
            <span class="skill-tag">Next.js</span>
            <span class="skill-tag">Tailwind CSS</span>
            <span class="skill-tag">HTML/CSS</span>
            <span class="skill-tag">Svelte</span>
          </div>
        </div>
      </div>
      <!-- Backend -->
      <div class="skill-category reveal-up" style="animation-delay:0.15s">
        <div class="rounded-2xl bg-white p-6 shadow-lg shadow-purple-100/50 border border-purple-100/30 hover:shadow-xl hover:shadow-purple-200/40 transition-all duration-300 hover:-translate-y-1 h-full">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-fuchsia-500 to-purple-500 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
          </div>
