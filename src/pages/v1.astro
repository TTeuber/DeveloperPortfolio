---
import Layout from '../Layouts/Layout.astro';
---

<Layout title="Tyler Teuber — Frontend Developer">
  <style>
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes slideRight {
      from { transform: scaleX(0); }
      to { transform: scaleX(1); }
    }
    @keyframes navDown {
      from { opacity: 0; transform: translateY(-100%); }
      to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-up {
      animation: fadeUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .animate-fade-in {
      animation: fadeIn 0.6s ease both;
    }
    .animate-slide-right {
      animation: slideRight 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
      transform-origin: left;
    }
    .animate-nav {
      animation: navDown 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }
    .delay-6 { animation-delay: 0.6s; }
    .delay-7 { animation-delay: 0.7s; }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 5rem;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #FAFAF9;
      color: #1a1a1a;
      overflow-x: hidden;
    }

    .font-mono {
      font-family: 'JetBrains Mono', monospace;
    }

    .section-number {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #64748b;
    }

    .accent { color: #475569; }
    .accent-bg { background-color: #475569; }
    .accent-border { border-color: #475569; }

    .project-card {
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 60px -12px rgba(0, 0, 0, 0.08);
    }

    .project-image-wrapper {
      overflow: hidden;
    }
    .project-image-wrapper img {
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .project-card:hover .project-image-wrapper img {
      transform: scale(1.03);
    }

    .nav-link {
      position: relative;
      transition: color 0.2s ease;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 1px;
      background: #475569;
      transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .nav-link:hover::after {
      width: 100%;
    }
    .nav-link:hover {
      color: #475569;
    }

    .skill-tag {
      transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }
    .skill-tag:hover {
      background-color: #475569;
      color: white;
      transform: translateY(-1px);
    }

    .divider {
      height: 1px;
      background: linear-gradient(to right, #e2e8f0, transparent);
    }

    .timeline-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #475569;
      flex-shrink: 0;
    }
    .timeline-line {
      width: 1px;
      background: #e2e8f0;
      flex-shrink: 0;
    }

    .contact-link {
      transition: color 0.2s ease, letter-spacing 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .contact-link:hover {
      color: #475569;
      letter-spacing: 0.02em;
    }

    /* Scroll-triggered animation */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <!-- Navigation -->
  <nav class="animate-nav fixed top-0 left-0 right-0 z-50 bg-[#FAFAF9]/90 backdrop-blur-md border-b border-stone-200/60">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 flex items-center justify-between h-14">
      <a href="#" class="font-mono text-xs font-medium tracking-widest uppercase text-stone-800">TT</a>
      <div class="hidden sm:flex items-center gap-8">
        <a href="#about" class="nav-link font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase">About</a>
        <a href="#projects" class="nav-link font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase">Projects</a>
        <a href="#experience" class="nav-link font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase">Experience</a>
        <a href="#skills" class="nav-link font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase">Skills</a>
        <a href="#contact" class="nav-link font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase">Contact</a>
      </div>
      <button id="mobile-menu-btn" class="sm:hidden p-2 -mr-2" aria-label="Toggle menu">
        <svg width="18" height="12" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="0" y1="1" x2="18" y2="1"/>
          <line x1="0" y1="6" x2="18" y2="6"/>
          <line x1="0" y1="11" x2="18" y2="11"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden border-t border-stone-200/60 bg-[#FAFAF9]/95 backdrop-blur-md">
      <div class="px-6 py-4 flex flex-col gap-3">
        <a href="#about" class="font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase py-1">About</a>
        <a href="#projects" class="font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase py-1">Projects</a>
        <a href="#experience" class="font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase py-1">Experience</a>
        <a href="#skills" class="font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase py-1">Skills</a>
        <a href="#contact" class="font-mono text-[0.6875rem] tracking-wide text-stone-500 uppercase py-1">Contact</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- ════════════════════════════════════ HERO ════════════════════════════════════ -->
    <section class="min-h-screen flex items-center pt-14">
      <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 w-full py-20 lg:py-0">
        <div class="grid lg:grid-cols-[1fr_auto] gap-12 lg:gap-20 items-center">
          <div>
            <p class="animate-fade-up section-number mb-6">Frontend Developer</p>
            <h1 class="animate-fade-up delay-1 text-5xl sm:text-6xl lg:text-7xl font-light tracking-tight text-stone-900 leading-[1.05]">
              Tyler<br/>
              <span class="font-extrabold">Teuber</span>
            </h1>
            <div class="animate-slide-right delay-3 w-16 h-[2px] accent-bg mt-8 mb-8"></div>
            <p class="animate-fade-up delay-3 text-base sm:text-lg text-stone-500 font-light leading-relaxed max-w-md">
              Building at the intersection of audio technology and the modern web — crafting interfaces that are as precise as they are human.
            </p>
            <div class="animate-fade-up delay-5 flex flex-wrap gap-4 mt-10">
              <a href="#projects" class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-mono tracking-wider uppercase accent-bg text-white hover:bg-stone-700 transition-colors duration-200">
                View Work
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 6h8m-3-3 3 3-3 3"/></svg>
              </a>
              <a href="#contact" class="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-mono tracking-wider uppercase border border-stone-300 text-stone-600 hover:border-stone-500 hover:text-stone-800 transition-colors duration-200">
                Get in Touch
              </a>
            </div>
          </div>
          <div class="animate-fade-in delay-4 relative hidden lg:block">
            <div class="w-72 h-80 relative">
              <div class="absolute inset-0 border border-stone-200 translate-x-3 translate-y-3"></div>
              <img
                src="/Images/Portrait.jpg"
                alt="Tyler Teuber"
                class="w-full h-full object-cover object-top relative z-10 grayscale-[20%]"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════ ABOUT ════════════════════════════════════ -->
    <section id="about" class="py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal">
          <div class="divider mb-12"></div>
          <div class="grid lg:grid-cols-[200px_1fr] gap-8 lg:gap-16">
            <div>
              <span class="section-number">01 — About</span>
            </div>
            <div class="max-w-2xl">
              <h2 class="text-2xl sm:text-3xl font-light text-stone-900 leading-snug mb-8">
                Self-taught developer with a <span class="font-semibold">mentor-guided</span> approach to building software.
              </h2>
              <div class="space-y-4 text-stone-500 font-light leading-relaxed">
                <p>
                  I came to software from an unconventional path — an Economics degree and Audio Technology minor from Western Washington University. Since 2022, I've been learning under a Senior Software Architect who I meet with every other week, turning curiosity into craft.
                </p>
                <p>
                  That audio background isn't incidental. It taught me to think about signal flow, real-time processing, and user experience in ways that directly translate to frontend engineering. I build interfaces with the same precision I bring to mixing a live signal chain.
                </p>
                <p>
                  I fully embrace modern development workflows, including agentic coding tools like Claude Code — not as a shortcut, but as a force multiplier for shipping thoughtful, well-architected software faster.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════ PROJECTS ════════════════════════════════════ -->
    <section id="projects" class="py-24 lg:py-32 bg-white">
      <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal">
          <div class="divider mb-12"></div>
          <div class="grid lg:grid-cols-[200px_1fr] gap-8 lg:gap-16 mb-16">
            <div>
              <span class="section-number">02 — Projects</span>
            </div>
            <div>
              <h2 class="text-2xl sm:text-3xl font-light text-stone-900">Selected Work</h2>
            </div>
          </div>
        </div>

        <!-- Project 1: Synthesizer VST -->
        <div class="reveal">
          <article class="project-card bg-[#FAFAF9] border border-stone-100 mb-8">
            <div class="grid md:grid-cols-2">
              <div class="project-image-wrapper aspect-[4/3] md:aspect-auto bg-stone-900">
                <img
                  src="/Images/Synth/Synth.png"
                  alt="Synthesizer VST interface showing oscillators, filters, and modulation controls"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-8 sm:p-10 lg:p-12 flex flex-col justify-center">
                <span class="font-mono text-[0.625rem] tracking-widest uppercase text-stone-400 mb-3">01</span>
                <h3 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-3">Synthesizer VST</h3>
                <p class="text-stone-500 font-light leading-relaxed mb-6">
                  A modern subtractive synthesizer with a gesture-based UI and Juno-inspired sound engine. Features a modulation matrix, custom effects chain (chorus, delay, reverb), multiple oscillators, and a novel "Modulation Mode" user experience.
                </p>
                <div class="flex flex-wrap gap-2">
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">C++</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">JUCE</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">DSP</span>
                </div>
              </div>
            </div>
          </article>
        </div>

        <!-- Project 2: Content Blocker -->
        <div class="reveal">
          <article class="project-card bg-[#FAFAF9] border border-stone-100 mb-8">
            <div class="grid md:grid-cols-2">
              <div class="p-8 sm:p-10 lg:p-12 flex flex-col justify-center order-2 md:order-1">
                <span class="font-mono text-[0.625rem] tracking-widest uppercase text-stone-400 mb-3">02</span>
                <h3 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-3">Self-Control Content Blocker</h3>
                <p class="text-stone-500 font-light leading-relaxed mb-6">
                  A bypass-resistant website and application blocker designed for a custom Arch Linux and Hyprland desktop. Comprises a desktop app with Python backend and TypeScript/React frontend, a Systemd daemon with Flask web server, and a Chrome extension.
                </p>
                <div class="flex flex-wrap gap-2">
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">Python</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">TypeScript</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">React</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">Flask</span>
                </div>
              </div>
              <div class="project-image-wrapper aspect-[4/3] md:aspect-auto bg-stone-900 order-1 md:order-2">
                <img
                  src="/Images/Blocker/WebsiteBlocker.png"
                  alt="Self-Control Content Blocker dashboard showing status and browser controls"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </article>
        </div>

        <!-- Project 3: Sermon Slides -->
        <div class="reveal">
          <article class="project-card bg-[#FAFAF9] border border-stone-100">
            <div class="grid md:grid-cols-2">
              <div class="project-image-wrapper aspect-[4/3] md:aspect-auto bg-stone-100">
                <img
                  src="/Images/SermonSlides/SermonSlidesGenerator.png"
                  alt="Sermon Slides Generator showing form interface for generating PDF slides"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-8 sm:p-10 lg:p-12 flex flex-col justify-center">
                <span class="font-mono text-[0.625rem] tracking-widest uppercase text-stone-400 mb-3">03</span>
                <h3 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-3">Sermon Slide Generator</h3>
                <p class="text-stone-500 font-light leading-relaxed mb-6">
                  A Python automation tool wrapped in a desktop app that replaces a manual process for church staff. Uses web scraping techniques to generate PDF slides used every week at The Redemption Church, with a clean HTML/CSS/JS frontend.
                </p>
                <div class="flex flex-wrap gap-2">
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">Python</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">HTML/CSS/JS</span>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase px-2.5 py-1 bg-stone-100 text-stone-500">Web Scraping</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════ EXPERIENCE ════════════════════════════════════ -->
    <section id="experience" class="py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal">
          <div class="divider mb-12"></div>
          <div class="grid lg:grid-cols-[200px_1fr] gap-8 lg:gap-16 mb-16">
            <div>
              <span class="section-number">03 — Experience</span>
            </div>
            <div>
              <h2 class="text-2xl sm:text-3xl font-light text-stone-900">Where I've Worked</h2>
            </div>
          </div>
        </div>

        <div class="lg:ml-[calc(200px+4rem)]">
          <!-- Job 1 -->
          <div class="reveal">
            <div class="flex gap-6 mb-12">
              <div class="flex flex-col items-center pt-2">
                <div class="timeline-dot"></div>
                <div class="timeline-line flex-1 mt-2"></div>
              </div>
              <div class="pb-8">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                  <h3 class="text-lg font-semibold text-stone-900">Coding Mind</h3>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase text-stone-400">Aug 2024 — Present</span>
                </div>
                <p class="text-sm font-medium text-stone-500 mb-3">Teacher & Assistant Manager · Redmond, WA</p>
                <ul class="space-y-2 text-stone-500 font-light text-sm leading-relaxed">
                  <li>Teach Python, JavaScript, and C++ to aspiring developers</li>
                  <li>Led curriculum development and student contributions to <span class="font-mono text-xs">playerpathwayproject.org</span> — TypeScript, React, and Tailwind on the frontend; Nest.js and Prisma on the backend</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Job 2 -->
          <div class="reveal">
            <div class="flex gap-6 mb-12">
              <div class="flex flex-col items-center pt-2">
                <div class="timeline-dot"></div>
                <div class="timeline-line flex-1 mt-2"></div>
              </div>
              <div class="pb-8">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                  <h3 class="text-lg font-semibold text-stone-900">Kill That Noise</h3>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase text-stone-400">Jun 2023 — Oct 2023</span>
                </div>
                <p class="text-sm font-medium text-stone-500 mb-3">Web Developer Intern · Remote</p>
                <ul class="space-y-2 text-stone-500 font-light text-sm leading-relaxed">
                  <li>Led a team of 5 interns migrating a WordPress sports news site to Next.js</li>
                  <li>Implemented Agile methodology to coordinate sprints and ensure timely delivery</li>
                  <li>Integrated Next.js with WordPress REST API for seamless content management</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Job 3 -->
          <div class="reveal">
            <div class="flex gap-6">
              <div class="flex flex-col items-center pt-2">
                <div class="timeline-dot"></div>
              </div>
              <div>
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                  <h3 class="text-lg font-semibold text-stone-900">DeveloperDB</h3>
                  <span class="font-mono text-[0.625rem] tracking-wider uppercase text-stone-400">Sep 2022 — Dec 2022</span>
                </div>
                <p class="text-sm font-medium text-stone-500 mb-3">Data Engineering Intern · Remote</p>
                <ul class="space-y-2 text-stone-500 font-light text-sm leading-relaxed">
                  <li>Built Python web scraping bots with Selenium to collect data from 10,000+ LinkedIn profiles</li>
                  <li>Designed new scraping architecture using alternative search engines for improved reliability</li>
                  <li>Processed and cleaned large datasets with Pandas, delivering structured CSV outputs</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════ SKILLS ════════════════════════════════════ -->
    <section id="skills" class="py-24 lg:py-32 bg-white">
      <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="reveal">
          <div class="divider mb-12"></div>
          <div class="grid lg:grid-cols-[200px_1fr] gap-8 lg:gap-16 mb-16">
            <div>
              <span class="section-number">04 — Skills</span>
            </div>
            <div>
              <h2 class="text-2xl sm:text-3xl font-light text-stone-900">Tech Stack</h2>
            </div>
          </div>
        </div>

        <div class="lg:ml-[calc(200px+4rem)]">
          <div class="grid sm:grid-cols-2 gap-12">
            <!-- Frontend -->
            <div class="reveal">
              <h3 class="font-mono text-[0.6875rem] tracking-widest uppercase text-stone-400 mb-4">Frontend</h3>
              <div class="flex flex-wrap gap-2">
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">React</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">TypeScript</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Next.js</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Tailwind CSS</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">HTML/CSS</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Svelte</span>
              </div>
            </div>

            <!-- Backend -->
            <div class="reveal">
              <h3 class="font-mono text-[0.6875rem] tracking-widest uppercase text-stone-400 mb-4">Backend</h3>
              <div class="flex flex-wrap gap-2">
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Python</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Node.js</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Nest.js</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Flask</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Prisma</span>
              </div>
            </div>

            <!-- Languages -->
            <div class="reveal">
              <h3 class="font-mono text-[0.6875rem] tracking-widest uppercase text-stone-400 mb-4">Languages</h3>
              <div class="flex flex-wrap gap-2">
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">JavaScript</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">TypeScript</span>
                <span class="skill-tag font-mono text-xs tracking-wide px-3 py-1.5 border border-stone-200 text-stone-600 cursor-default">Python</span>
