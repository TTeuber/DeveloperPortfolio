---
import Layout from '../Layouts/Layout.astro';
import ScrollProgress from '../components/v5/ScrollProgress.svelte';
import SkillRadar from '../components/v5/SkillRadar.svelte';
import ProjectCard from '../components/v5/ProjectCard.svelte';
---

<Layout title="Tyler Teuber | Interactive Portfolio">
  <ScrollProgress client:load />

  <!-- NAV -->
  <nav id="v5-nav" class="fixed top-1 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center bg-neutral-950/70 backdrop-blur-xl rounded-2xl border border-neutral-800/50 mt-2">
      <a href="#" class="text-lg font-bold text-amber-400 font-mono tracking-tight">TT</a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300">About</a>
        <a href="#projects" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300">Projects</a>
        <a href="#experience" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300">Experience</a>
        <a href="#skills" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300">Skills</a>
        <a href="#contact" class="text-sm px-4 py-2 rounded-full bg-amber-500 text-neutral-900 font-medium hover:bg-amber-400 transition-colors duration-300">Contact</a>
      </div>
      <button id="mobile-menu-btn" class="md:hidden text-neutral-400 hover:text-amber-400 transition-colors cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden max-w-6xl mx-auto px-6 mt-2">
      <div class="bg-neutral-950/90 backdrop-blur-xl rounded-xl border border-neutral-800/50 p-4 flex flex-col gap-3">
        <a href="#about" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300 py-2">About</a>
        <a href="#projects" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300 py-2">Projects</a>
        <a href="#experience" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300 py-2">Experience</a>
        <a href="#skills" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300 py-2">Skills</a>
        <a href="#contact" class="text-sm text-neutral-400 hover:text-amber-400 transition-colors duration-300 py-2">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-neutral-950">
    <!-- Animated geometric background -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="hero-grid absolute inset-0 opacity-[0.03]"></div>
      <div class="geo geo-1"></div>
      <div class="geo geo-2"></div>
      <div class="geo geo-3"></div>
      <div class="geo geo-4"></div>
      <div class="geo geo-5"></div>
      <div class="geo geo-6"></div>
      <!-- Radial glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-amber-500/5 blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-32 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-amber-500 font-mono text-sm mb-4 hero-fade hero-fade-1">&gt; hello world</p>
        <h1 class="mb-4">
          <span class="hero-name text-5xl sm:text-6xl lg:text-7xl font-extrabold text-neutral-100 block leading-tight">
            {Array.from("Tyler Teuber").map((letter, i) => (
              <span class="hero-letter inline-block" style={`animation-delay: ${i * 0.05}s`}>
                {letter === " " ? "\u00A0" : letter}
              </span>
            ))}
          </span>
        </h1>
        <p class="text-xl sm:text-2xl text-amber-400 font-medium mb-4 hero-fade hero-fade-2">Frontend Developer</p>
        <p class="text-neutral-400 text-lg max-w-md leading-relaxed mb-8 hero-fade hero-fade-3">
          Building at the intersection of <span class="text-neutral-200">audio technology</span> and <span class="text-neutral-200">modern web development</span>. Crafting experiences that sound as good as they look.
        </p>
        <div class="flex flex-wrap gap-4 hero-fade hero-fade-4">
          <a href="#projects" class="px-6 py-3 rounded-full bg-amber-500 text-neutral-900 font-semibold hover:bg-amber-400 transition-all duration-300 hover:shadow-lg hover:shadow-amber-500/25 hover:-translate-y-0.5">
            View Projects
          </a>
          <a href="#contact" class="px-6 py-3 rounded-full border border-neutral-700 text-neutral-300 font-medium hover:border-amber-500/50 hover:text-amber-400 transition-all duration-300 hover:-translate-y-0.5">
            Get in Touch
          </a>
        </div>
      </div>
      <div class="flex justify-center hero-fade hero-fade-3">
        <div class="relative">
          <div class="absolute -inset-4 rounded-full bg-gradient-to-tr from-amber-500/20 via-transparent to-amber-600/10 blur-xl animate-pulse-slow"></div>
          <img
            src="/Images/Portrait.jpg"
            alt="Tyler Teuber"
            class="relative w-64 h-64 sm:w-80 sm:h-80 rounded-full object-cover border-2 border-amber-500/30 shadow-2xl"
          />
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hero-fade hero-fade-5">
      <div class="w-6 h-10 rounded-full border-2 border-neutral-700 flex justify-center pt-2">
        <div class="w-1 h-2 rounded-full bg-amber-500 animate-scroll-dot"></div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="relative py-24 sm:py-32 bg-neutral-950">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal">
        <p class="text-amber-500 font-mono text-sm mb-2">&gt; about</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-100 mb-12">The Story So Far</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 space-y-5 reveal">
          <p class="text-neutral-300 leading-relaxed text-lg">
            I'm a self-taught developer with a passion for building things that matter. After graduating from <span class="text-amber-400">Western Washington University</span> with a degree in Economics and a minor in Audio Technology, I discovered that the same creative problem-solving that drew me to audio engineering was at the heart of software development.
          </p>
          <p class="text-neutral-400 leading-relaxed">
            Since 2022, I've been mentored by a <span class="text-neutral-200">Senior Software Architect</span> who has guided my journey from beginner to building full-stack applications. This mentorship, combined with hands-on project work, has given me a strong foundation in modern frontend development.
          </p>
          <p class="text-neutral-400 leading-relaxed">
            I work at the intersection of audio and code — whether that's building synthesizer plugins in C++ or crafting responsive web experiences with React and TypeScript. I'm a firm believer in leveraging modern tools like <span class="text-neutral-200">Claude Code</span> to accelerate development without sacrificing code quality.
          </p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 lg:grid-cols-1 gap-4">
          <div class="stat-card reveal rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 text-center" data-target="3" data-suffix="+">
            <div class="text-4xl font-bold text-amber-400 font-mono stat-number">0</div>
            <div class="text-sm text-neutral-500 mt-1">Years Coding</div>
          </div>
          <div class="stat-card reveal rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 text-center" data-target="4" data-suffix="">
            <div class="text-4xl font-bold text-amber-400 font-mono stat-number">0</div>
            <div class="text-sm text-neutral-500 mt-1">Projects Shipped</div>
          </div>
          <div class="stat-card reveal rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 text-center" data-target="10" data-suffix="k+">
            <div class="text-4xl font-bold text-amber-400 font-mono stat-number">0</div>
            <div class="text-sm text-neutral-500 mt-1">Lines of Code</div>
          </div>
          <div class="stat-card reveal rounded-xl border border-neutral-800 bg-neutral-900/50 p-6 text-center" data-target="1" data-suffix="">
            <div class="text-4xl font-bold text-amber-400 font-mono stat-number">0</div>
            <div class="text-sm text-neutral-500 mt-1">Mentor</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="relative py-24 sm:py-32 bg-neutral-950">
    <div class="max-w-6xl mx-auto px-6">
      <div class="reveal">
        <p class="text-amber-500 font-mono text-sm mb-2">&gt; projects</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-100 mb-4">Featured Work</h2>
        <p class="text-neutral-400 max-w-2xl mb-12">A selection of projects showcasing my range — from low-level audio DSP to full-stack web applications.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <ProjectCard
          client:visible
          title="Synthesizer VST"
          description="A subtractive synthesizer plugin with a gesture-based UI inspired by the Juno sound engine. Built from the ground up with custom DSP algorithms."
          image="/Images/Synth/Synth.png"
          tech={["C++", "JUCE", "DSP"]}
          features={["Modulation Matrix", "Effects Chain", "Multi-Oscillator", "Modulation Mode UX"]}
        />
        <ProjectCard
          client:visible
          title="Self-Control Content Blocker"
          description="A bypass-resistant website and application blocker for Arch Linux with Hyprland integration. Full-stack with Chrome extension."
          image="/Images/Blocker/WebsiteBlocker.png"
          tech={["Python", "TypeScript", "React", "Flask"]}
          features={["Bypass-Resistant", "Chrome Extension", "Hyprland Integration", "Tailwind UI"]}
        />
        <ProjectCard
          client:visible
          title="Sermon Slide Generator"
          description="Python automation tool for church staff at The Redemption Church. Scrapes sermon content and generates presentation-ready PDF slides."
          image="/Images/SermonSlides/SermonSlidesGenerator.png"
          tech={["Python", "HTML/CSS/JS", "Web Scraping"]}
          features={["Web Scraping", "PDF Generation", "Automated Pipeline", "Staff-Friendly"]}
        />
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="experience" class="relative py-24 sm:py-32 bg-neutral-950">
    <div class="max-w-4xl mx-auto px-6">
      <div class="reveal">
        <p class="text-amber-500 font-mono text-sm mb-2">&gt; experience</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-100 mb-12">Where I've Worked</h2>
      </div>

      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute left-0 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-amber-500 via-amber-500/50 to-neutral-800"></div>

        <!-- Entry 1 -->
        <div class="timeline-entry reveal relative pl-8 sm:pl-20 pb-14">
          <div class="absolute left-0 sm:left-8 top-1 w-3 h-3 -translate-x-1/2 rounded-full bg-amber-500 border-4 border-neutral-950 ring-2 ring-amber-500/30"></div>
          <div class="absolute left-0 sm:left-8 top-1 w-3 h-3 -translate-x-1/2 rounded-full bg-amber-500 animate-ping opacity-30"></div>
          <p class="text-amber-500 font-mono text-xs mb-1">Aug 2024 — Present</p>
          <h3 class="text-xl font-bold text-neutral-100 mb-1">Teacher / Assistant Manager</h3>
          <p class="text-neutral-400 text-sm mb-3">Coding Mind &middot; Redmond, WA</p>
          <ul class="space-y-2 text-neutral-400 text-sm leading-relaxed">
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Teach Python, JavaScript, and C++ to students of various skill levels</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Led curriculum development for <span class="text-neutral-200">playerpathwayproject.org</span> — TypeScript, React, Tailwind with Nest.js and Prisma backend</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Manage day-to-day operations and assist with team coordination</li>
          </ul>
        </div>

        <!-- Entry 2 -->
        <div class="timeline-entry reveal relative pl-8 sm:pl-20 pb-14">
          <div class="absolute left-0 sm:left-8 top-1 w-3 h-3 -translate-x-1/2 rounded-full bg-amber-500/60 border-4 border-neutral-950"></div>
          <p class="text-neutral-500 font-mono text-xs mb-1">Jun — Oct 2023</p>
          <h3 class="text-xl font-bold text-neutral-100 mb-1">Web Developer Intern</h3>
          <p class="text-neutral-400 text-sm mb-3">Kill That Noise &middot; Remote</p>
          <ul class="space-y-2 text-neutral-400 text-sm leading-relaxed">
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Led a team of 5 interns on a WordPress to Next.js migration</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Practiced Agile methodology with sprint-based development cycles</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Integrated REST APIs and implemented responsive UI components</li>
          </ul>
        </div>

        <!-- Entry 3 -->
        <div class="timeline-entry reveal relative pl-8 sm:pl-20">
          <div class="absolute left-0 sm:left-8 top-1 w-3 h-3 -translate-x-1/2 rounded-full bg-neutral-600 border-4 border-neutral-950"></div>
          <p class="text-neutral-500 font-mono text-xs mb-1">Sep — Dec 2022</p>
          <h3 class="text-xl font-bold text-neutral-100 mb-1">Data Engineering Intern</h3>
          <p class="text-neutral-400 text-sm mb-3">DeveloperDB &middot; Remote</p>
          <ul class="space-y-2 text-neutral-400 text-sm leading-relaxed">
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Built Selenium web scrapers to extract 10,000+ developer profiles</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Processed and cleaned data pipelines using Pandas</li>
            <li class="flex gap-2"><span class="text-amber-500 mt-0.5 shrink-0">&rsaquo;</span> Delivered structured datasets for business intelligence analysis</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="relative py-24 sm:py-32 bg-neutral-950">
    <div class="max-w-5xl mx-auto px-6">
      <div class="reveal">
        <p class="text-amber-500 font-mono text-sm mb-2">&gt; skills</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-100 mb-12">Technical Toolkit</h2>
      </div>
      <div class="reveal">
        <SkillRadar client:visible />
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="relative py-24 sm:py-32 bg-neutral-950">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="reveal">
        <p class="text-amber-500 font-mono text-sm mb-2">&gt; contact</p>
        <h2 class="text-3xl sm:text-5xl font-bold text-neutral-100 mb-6">Let's Build Something</h2>
        <p class="text-neutral-400 text-lg mb-10 max-w-lg mx-auto">
          I'm always open to new opportunities, collaborations, or just a good conversation about audio tech and web development.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 reveal">
        <a
          href="mailto:hello@tylerteuber.com"
          class="group flex items-center gap-3 px-6 py-4 rounded-xl border border-neutral-800 bg-neutral-900/50 hover:border-amber-500/50 transition-all duration-300 hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-neutral-300 group-hover:text-amber-400 transition-colors">Email</span>
        </a>
        <a
          href="https://github.com/TTeuber"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 px-6 py-4 rounded-xl border border-neutral-800 bg-neutral-900/50 hover:border-amber-500/50 transition-all duration-300 hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          <span class="text-neutral-300 group-hover:text-amber-400 transition-colors">GitHub</span>
        </a>
        <a
          href="https://www.linkedin.com/in/tyler-teuber/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 px-6 py-4 rounded-xl border border-neutral-800 bg-neutral-900/50 hover:border-amber-500/50 transition-all duration-300 hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          <span class="text-neutral-300 group-hover:text-amber-400 transition-colors">LinkedIn</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 bg-neutral-950 border-t border-neutral-900">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-neutral-600 text-sm">&copy; 2026 Tyler Teuber. Built with Astro, Svelte & Tailwind CSS.</p>
    </div>
  </footer>
</Layout>

<style>
  /* Geometric background shapes */
  .hero-grid {
    background-image:
      linear-gradient(rgba(245,158,11,0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,158,11,0.3) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .geo {
    position: absolute;
    border: 1px solid rgba(245,158,11,0.08);
    border-radius: 2px;
  }

  .geo-1 {
    width: 200px;
    height: 200px;
    top: 10%;
    left: 5%;
    transform: rotate(45deg);
    animation: geo-float 20s ease-in-out infinite;
  }

  .geo-2 {
    width: 120px;
    height: 120px;
    top: 60%;
    right: 10%;
    border-radius: 50%;
    animation: geo-float 15s ease-in-out infinite reverse;
  }

  .geo-3 {
    width: 80px;
    height: 80px;
    bottom: 20%;
    left: 15%;
    transform: rotate(30deg);
    animation: geo-float 18s ease-in-out infinite 2s;
  }

  .geo-4 {
    width: 150px;
    height: 150px;
    top: 20%;
    right: 20%;
    transform: rotate(60deg);
    animation: geo-float 22s ease-in-out infinite 1s;
  }

  .geo-5 {
    width: 60px;
    height: 60px;
    top: 40%;
    left: 30%;
    border-radius: 50%;
    animation: geo-float 12s ease-in-out infinite 3s;
  }

  .geo-6 {
    width: 100px;
    height: 100px;
    bottom: 30%;
    right: 30%;
    transform: rotate(15deg);
    animation: geo-float 17s ease-in-out infinite 4s;
  }

  @keyframes geo-float {
    0%, 100% { transform: translateY(0) rotate(var(--r, 45deg)); opacity: 1; }
    50% { transform: translateY(-30px) rotate(var(--r, 45deg)); opacity: 0.5; }
  }

  .geo-1 { --r: 45deg; }
  .geo-3 { --r: 30deg; }
  .geo-4 { --r: 60deg; }
  .geo-6 { --r: 15deg; }
  .geo-2, .geo-5 { --r: 0deg; }

  /* Hero letter animation */
  .hero-letter {
    opacity: 0;
    transform: translateY(20px);
    animation: letter-in 0.5s ease-out forwards;
  }

  @keyframes letter-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hero fade-in stagger */
  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: fade-up 0.7s ease-out forwards;
  }

  .hero-fade-1 { animation-delay: 0.3s; }
  .hero-fade-2 { animation-delay: 0.9s; }
  .hero-fade-3 { animation-delay: 1.1s; }
  .hero-fade-4 { animation-delay: 1.3s; }
  .hero-fade-5 { animation-delay: 1.6s; }

  @keyframes fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll dot animation */
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.3; }
  }

  .animate-scroll-dot {
    animation: scroll-bounce 1.5s ease-in-out infinite;
  }

  /* Pulse slow */
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Smooth scroll */
  html {
    scroll-behavior: smooth;
  }

  /* Timeline entries stagger */
  .timeline-entry.reveal {
    transition-delay: var(--delay, 0s);
  }
</style>

<script>
  // Scroll-triggered reveal animations
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el, i) => {
    const parent = el.closest('section');
    const siblings = parent ? Array.from(parent.querySelectorAll('.reveal')) : [];
    const index = siblings.indexOf(el);
    el.style.setProperty('--delay', `${index * 0.1}s`);
    revealObserver.observe(el);
  });

  // Counter animation for stat cards
  const statObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const card = entry.target;
          const numberEl = card.querySelector('.stat-number');
          const target = parseInt(card.dataset.target || '0');
          const suffix = card.dataset.suffix || '';
          let current = 0;
          const duration = 1500;
          const step = Math.max(1, Math.floor(target / (duration / 30)));
          const interval = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(interval);
            }
            numberEl.textContent = current + suffix;
          }, 30);
          statObserver.unobserve(card);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll('.stat-card').forEach((el) => {
    statObserver.observe(el);
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // Mouse-following subtle glow effect on hero
  const hero = document.querySelector('section');
  if (hero) {
    const glow = document.createElement('div');
    glow.style.cssText = 'position:fixed;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(245,158,11,0.04) 0%,transparent 70%);pointer-events:none;z-index:1;transition:transform 0.3s ease-out;transform:translate(-50%,-50%)';
    document.body.appendChild(glow);

    document.addEventListener('mousemove', (e) => {
      glow.style.left = e.clientX + 'px';
      glow.style.top = e.clientY + 'px';
    });
  }

  // Active nav link highlighting
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('nav a[href^="#"]');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach((section) => {
      const sectionTop = section.offsetTop - 100;
      if (window.scrollY >= sectionTop) {
        current = section.getAttribute('id') || '';
      }
    });

    navLinks.forEach((link) => {
      link.classList.remove('text-amber-400');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('text-amber-400');
      }
    });
  }, { passive: true });
</script>
