      </div>

      <div class="timeline-item reveal">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <div class="timeline-header">
            <h3>Data Engineering Intern</h3>
            <span class="timeline-meta">DeveloperDB &middot; Remote</span>
