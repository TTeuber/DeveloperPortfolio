---
// Per-project detail page: a shareable URL with the long-form write-up from
// `details` in src/data/projects.js.
import { getImage } from 'astro:assets';
import Layout from '../../Layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Carousel from '../../components/Carousel.svelte';
import { projects } from '../../data/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

// Optimized responsive variants for the media block. GIF entries (plain path
// strings) skip the pipeline; `portrait` flags phone screenshots so the
// carousel letterboxes them instead of crop-zooming.
const media = await Promise.all(
  (project.images ?? []).map(async (image) => {
    if (typeof image === 'string') return { src: image };
    const img = await getImage({
      src: image,
      format: 'webp',
      widths: [720, 1440],
      sizes: '(min-width: 920px) 860px, 100vw',
    });
    return {
      src: img.src,
      srcset: img.srcSet.attribute,
      sizes: img.attributes.sizes,
      portrait: image.height > image.width,
    };
  })
);
---

<Layout title={`${project.title} | Tyler Teuber`} description={project.description}>

<Nav />

<main class="detail-page" style={`--h: ${project.accent}`}>
  <div class="container narrow">
    <a href="/#projects" class="back-link">&larr; All projects</a>

    <header class="detail-head">
      <p class="detail-context"><span class="detail-led" aria-hidden="true"></span>{project.context}</p>
      <h1>{project.title}</h1>
      <div class="detail-tags">
        {project.tags.map((tag) => <span class="detail-tag">{tag}</span>)}
      </div>
    </header>

    {media.length > 1 ? (
      <div class="detail-media-slot">
        <Carousel client:load images={media} title={project.title} />
      </div>
    ) : media.length === 1 && (
      <div class="detail-media">
        <img
          src={media[0].src}
          srcset={media[0].srcset}
          sizes={media[0].sizes}
          alt={`${project.title} screenshot`}
        />
      </div>
    )}

    <div class="detail-body">
      {(project.details ?? [project.description]).map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <div class="detail-actions">
      {project.links.code && (
        <a href={project.links.code} target="_blank" rel="noopener noreferrer" class="btn btn-primary">See the Code</a>
      )}
      {project.links.demo && (
        <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Live Demo</a>
      )}
      {project.video && (
        <a href={`https://www.youtube.com/watch?v=${project.video}`} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Watch the Demo</a>
      )}
    </div>
  </div>
</main>

<Footer />

</Layout>

<style lang="scss">
  .detail-page {
    padding: 140px 0 96px;
    min-height: 70vh;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-dim);
    margin-bottom: 36px;

    &:hover {
      color: var(--amber);
    }
  }

  .detail-head {
    margin-bottom: 36px;

    h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 0 0 18px;
      color: var(--text);
    }
  }

  .detail-context {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin: 0 0 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .detail-led {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    background: hsl(var(--h), 75%, 62%);
    box-shadow: 0 0 8px hsla(var(--h), 85%, 60%, 0.8);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .detail-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 5px 12px;
    border-radius: 100px;
    border: 1px solid var(--line);
    color: var(--text-dim);
    background: var(--panel);
  }

  .detail-media-slot {
    margin-bottom: 40px;
  }

  .detail-media {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-deep);
    margin-bottom: 40px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);

    img {
      width: 100%;
      height: auto;
      display: block;
    }
  }

  .detail-body {
    margin-bottom: 40px;

    p {
      font-size: 1.0625rem;
      line-height: 1.8;
      color: var(--text-dim);
      margin: 0 0 20px;

      &:last-child {
        margin-bottom: 0;
      }
    }
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
</style>
